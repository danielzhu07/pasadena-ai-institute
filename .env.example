# ─────────────────────────────────────────────────────────────
# Pasadena AI Workshop — environment variables
# Copy this file to `.env.local` and fill in real values.
#
# Local dev runs fully WITHOUT any of these (graceful fallbacks):
#   • Interest form  → writes leads to /data/leads.json + server log
#   • Stripe button  → shows a "Reserve by application" fallback state
#
# PRODUCTION (Vercel) NOTE: the filesystem is read-only/ephemeral on
# Vercel, so the /data/leads.json fallback does NOT persist there.
# Set RESEND_API_KEY + LEAD_NOTIFY_EMAIL in production so every lead is
# emailed to you. Without them, production submissions are not captured.
# ─────────────────────────────────────────────────────────────

# Public site URL (used for absolute links, OG tags, Stripe redirects).
# In local dev you can leave this unset (defaults to http://localhost:3000).
# In production set to your real domain, e.g. https://whistleworkshop.com
NEXT_PUBLIC_SITE_URL=

# ── Stripe (paid registration) ──────────────────────────────
# Secret key from https://dashboard.stripe.com/apikeys
# Use a test key (sk_test_...) until you're ready to go live (sk_live_...).
# No dashboard product needed — price is created inline at $1,000.
# Create Stripe promotion codes for $500-off and 100%-off scholarships.
STRIPE_SECRET_KEY=
# Optional public key if a future client-side Stripe flow needs it.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Optional Stripe product ID to attach the inline checkout price to.
STRIPE_PRODUCT_ID=
# Webhook signing secret from Stripe after adding:
# https://your-domain.com/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=

# ── Resend (interest-form email notifications) ──────────────
# API key from https://resend.com/api-keys
# When set, each interest-form submission emails you a lead notification.
RESEND_API_KEY=
# Where lead notifications are sent. Separate multiple inboxes with commas:
LEAD_NOTIFY_EMAIL=
# Verified "from" address for Resend (e.g. hello@whistleworkshop.com).
# Falls back to onboarding@resend.dev if unset (Resend test sender).
RESEND_FROM_EMAIL=
